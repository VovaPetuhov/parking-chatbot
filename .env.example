# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# DeepLake Configuration
DEEPLAKE_TOKEN=your-deeplake-token-here
DEEPLAKE_ORG_ID=your-org-id-here
DEEPLAKE_DATASET_PATH=hub://your-org/parking-chatbot

# Application Settings
APP_NAME=Parking Reservation Chatbot
APP_VERSION=1.0.0
DEBUG_MODE=false
LOG_LEVEL=INFO
QUIET_MODE=false  # Set to true to disable all console logging

# LLM Settings
OPENAI_MODEL_NAME=gpt-4o
OPENAI_TEMPERATURE=0.0
MAX_TOKENS=1000

DATA_EXTRACTION_MODEL=gpt-4o

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.0

# Guardrails Settings
ENABLE_PII_DETECTION=true
ENABLE_SENSITIVE_DATA_FILTER=true
PII_SCORE_THRESHOLD=0.5

# Parking Info
PARKING_NAME=City Parking
PARKING_ADDRESS=Bratislava, Street, 10
PARKING_CAPACITY=150
WORKING_HOURS_WEEKDAY=06:00-23:00
WORKING_HOURS_WEEKEND=08:00-22:00
PRICE_PER_HOUR=2.00
PRICE_PER_DAY=20.00

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# Session Management
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000

# Reservation Management
RESERVATION_TTL_SECONDS=3600
MAX_RESERVATIONS=10000
